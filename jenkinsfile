pipeline {
    agent any

    environment {
        IMAGE_NAME = "flask-calculator-app"
        CONTAINER_NAME = "flask-calculator-container"
        PORT = "5000"
    }

    stages {

        stage('Checkout') {
            steps {
                git url: 'https://github.com/YOUR_USERNAME/YOUR_REPO.git', branch: 'main'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t $IMAGE_NAME .'
            }
        }

        stage('Clean Old Container') {
            steps {
                sh '''
                docker ps -a | grep $CONTAINER_NAME && docker stop $CONTAINER_NAME || true
                docker ps -a | grep $CONTAINER_NAME && docker rm $CONTAINER_NAME || true
                '''
            }
        }

        stage('Run Container') {
            steps {
                sh '''
                docker run -d -p $PORT:$PORT --name $CONTAINER_NAME $IMAGE_NAME
                '''
            }
        }
    }

    post {
        always {
            echo 'Pipeline execution completed.'
        }
        success {
            echo 'App deployed successfully 🚀'
        }
        failure {
            echo 'Something went wrong ❌'
        }
    }
}