pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                git url: 'https://github.com/pranatidasrk/Addition.git', branch: 'main'
            }
        }

        stage('Set Minikube Docker Env') {
            steps {
                bat '''
                @echo off
                for /f "tokens=*" %%i in ('minikube docker-env --shell cmd') do %%i
                '''
            }
        }

        stage('Build Docker Image') {
            steps {
                bat 'docker build -t addition:v1 .'
            }
			
			stage('stop container') {
            steps { 
			script {
			try { 
			
			bat '''
			docker stop sangu
			docker rm sangu
			'''
               }
			   catch (err)
			   {
			   println("stage fail but continue")
			   }
			   }
			   
            }
        }
        }

		
		stage('Dockerhub push ') {
            steps {
			steps {
                withCredentials([string(credentialsId: 'dockerhub_token', variable: 'DOCKER_TOKEN')]) {
                    bat '''
					docker tag pranatidasrk/addition:v4 addition:v1
                    docker login -u pranatidasrk -p $DOCKER_TOKEN https://hub.docker.com/repositories/pranatidasrk
					docker push pranatidasrk/addition:v4
					docker logout
                    '''
                }
            }
       
            }
        }

   /*    stage('Deploy to Minikube') {
            steps {
                script {
                    try {
                        bat '''
                        kubectl delete -f flask-app.yaml
                        '''
                    } catch (err) {
                        echo "Old deployment not found, continuing..."
                    }

                    bat '''
                    kubectl apply -f flask-app.yaml
                    kubectl get pods
                    kubectl get svc
                    '''
                }
            }
        } */
		
		stage('Run Container') {
            steps {
                bat '''
                docker run -itd -p 8081:5000 addition:v1
                '''
            }
        }
    }

    post {
        always {
            echo 'Pipeline execution completed.'
        }
        success {
            echo 'App deployed in Minikube 🚀'
        }
        failure {
            echo 'Something went wrong ❌'
        }
    }
}
