pipeline {
    agent any
	
    parameters { 
        string(name: 'IMAGE_TAG', defaultValue: 'v1', description: 'Docker Image Tag')
    }

    environment {
        IMAGE_NAME = "pranatidasrk/addition"
        RELEASE_NAME = "my-release"
        NAMESPACE = "namespace2"
        CHART_PATH = "helm-chat"
    }

    stages {

        stage('Checkout') {
            steps {
                git url: 'https://github.com/pranatidasrk/Addition.git', branch: 'main'
            }
        }

        stage('Build Docker Image') {
            steps {
                bat '''
                docker build -t %IMAGE_NAME%:%IMAGE_TAG% .
                '''
            }
        }
			
        stage('stop container') {
            steps { 
                script {
                    try { 
                        bat '''
                        docker stop sangu
                        docker rm sangu
                        '''
                    } catch (err) {
                        println("stage fail but continue")
                    }
                }
            }
        }

        // ✅ FIXED DockerHub push
        stage('Dockerhub push') {
            steps {
                withCredentials([string(credentialsId: 'dockerhub_token', variable: 'DOCKER_TOKEN')]) {
                    bat '''
                    docker tag %IMAGE_NAME%:%IMAGE_TAG% %IMAGE_NAME%:%IMAGE_TAG%
                    docker login -u pranatidasrk -p %DOCKER_TOKEN%
                    docker push %IMAGE_NAME%:%IMAGE_TAG%
                    docker logout
                    '''
                }
            }
        }

        // ✅ NEW: Helm Deployment (replaces docker run)
        stage('Deploy to Minikube using Helm') {
            steps {
                bat '''
                helm upgrade --install my-release helm-chat \
                --namespace namespace2 \
                --create-namespace \
                --set image.repository=pranatidasrk/addition \
                --set image.tag=v1
                '''
            }
        }

        // ✅ Verification
        stage('Verify') {
            steps {
                bat '''
                kubectl get pods -n %NAMESPACE%
                kubectl get svc -n %NAMESPACE%
                '''
            }
        }
    }

    post {
        always {
            echo 'Pipeline execution completed.'
        }
        success {
            echo 'App deployed in Minikube via Helm 🚀'
        }
        failure {
            echo 'Something went wrong ❌'
        }
    }
}
