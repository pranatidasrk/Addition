pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                git url: 'https://github.com/pranatidasrk/Addition.git', branch: 'main'
            }
        }

        stage('Build Docker Image') {
            steps {
                bat 'docker build -t addition:v1 .'
            }
       
        }
		
		stage('stop container') {
            steps { 
			script {
			try { 
			
			bat '''
			docker stop sangu
			docker rm sangu
			'''
               }
			   catch (err)
			   {
			   println("stage fail but continue")
			   }
			   }
			   
            }
        }

        stage('Run Container') {
            steps {
                bat '''
                docker run -itd -p 8081:5000 --name sangu addition:v1
                '''
            }
        }
    }

    post {
        always {
            echo 'Pipeline execution completed.'
        }
        success {
            echo 'App deployed successfully 🚀'
        }
        failure {
            echo 'Something went wrong ❌'
        }
    }
}
