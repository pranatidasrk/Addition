apiVersion: apps/v1
kind: Deployment
metadata:
  name: addition-deployment
spec:
  replicas: 1
  selector:
    matchLabels:
      app: addition
  template:
    metadata:
      labels:
        app: addition
    spec:
      containers:
      - name: addition-container
        image: pranatidasrk/addition:v1
        ports:
        - containerPort: 5000
---
apiVersion: v1
kind: Service
metadata:
  name: addition-service
spec:
  type: NodePort
  selector:
    app: addition
  ports:
    - protocol: TCP
      port: 80
      targetPort: 5000
      nodePort: 30007
